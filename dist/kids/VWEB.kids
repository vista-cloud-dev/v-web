"RTN","VWEBT",260,0)
	set s=s_"g('rearm').addEventListener('click',function(){tap('rearm')});"_nl
"RTN","VWEBT",261,0)
	set s=s_"openStream();"
"RTN","VWEBT",262,0)
	quit s
