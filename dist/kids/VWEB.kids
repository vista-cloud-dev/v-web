VWEBENV	; v-web — KIDS environment check (spec §14). Run by KIDS at load/install.
"RTN","VWEBENV",2,0)
	;
"RTN","VWEBENV",3,0)
	; Extends VSLENV's base facts (engine/version/kernel/tls) with VWEB's
"RTN","VWEBENV",4,0)
